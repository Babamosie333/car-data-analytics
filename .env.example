# ============================================================
# .env  —  Environment variables for Car Analytics Dashboard
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- MongoDB ---
# Local development (default if this line is commented out):
# MONGODB_URI=mongodb://127.0.0.1:27017

# MongoDB Atlas (recommended for production):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Name of the database to use (created automatically if absent)
#DB_NAME=car_analytics

# --- Session ---
# Generate a strong random string for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Server ---
PORT=3000
